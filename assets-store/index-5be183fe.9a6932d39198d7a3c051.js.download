       <div style='border:2px solid #EAEBED;border-radius:10px;' class='mt-3'>\n                                <div class='d-flex gap-1 flex-column' style='padding:24px;'>\n                                    <div class='d-flex gap-1 align-items-center justify-space-between w-100'>\n                                        <div class='d-flex gap-2 align-items-center w-100'>\n                                            <h2 class='ff_made_medium m-0' style='font-size:16px;font-weight:500;color:#10182F;'>Strictly Necessary Cookies</h2>\n                                        </div>\n                                        <h2 class='ff_made_medium m-0 text-sm-nowrap text-end' style='font-size:16px;font-weight:500;color:#08247D;'>Always Active</h2>\n                                        \n                                    </div>\n                                    <div>\n                                        <p class=\"text-wrap ff_made ls-4 me-0 ms-0 mb-0 mt-3\" style='font-size:14px;font-weight:400;color:#000000;'>These cookies are essential for providing our services and cannot be disabled. They enable key features like account creation and wishlist saving. Blocking or alerting these cookies may impact site functionality.</p>\n                                    </div>\n                                </div>\n                                <div class='d-flex gap-1 flex-column' style='padding:24px;border-top:2px solid #EAEBED;'>\n                                    <div class='d-flex gap-1 align-items-center justify-space-between w-100'>\n                                        <div class='d-flex gap-2 align-items-center w-100'>\n                                            <h2 class='ff_made_medium m-0' style='font-size:16px;font-weight:500;color:#10182F;'>Performance Cookies</h2>\n                                        </div>\n                                        <div class=\"form-check\">\n                                            <input class=\"form-check-input\" type=\"checkbox\" value=\"\" id=\"flexCheckChecked\" aria-label=\"Performance Cookies\" checked style='margin-left:unset;'>\n                                        </div>\n                                        \n                                    </div>\n                                    <div>\n                                        <p class=\"text-wrap ff_made ls-4 me-0 ms-0 mb-0 mt-3\" style='font-size:14px;font-weight:400;color:#000000;'>These cookies collect anonymous data to analyze website usage, such as visitor numbers and pages viewed. This helps us improve site performance.</p>\n                                    </div>\n                                </div>\n                                <div class='d-flex gap-1 flex-column' style='padding:24px;border-top:2px solid #EAEBED;'>\n                                    <div class='d-flex gap-1 align-items-center justify-space-between w-100'>\n                                        <div class='d-flex gap-2 align-items-center w-100'>\n                                            <h2 class='ff_made_medium m-0' style='font-size:16px;font-weight:500;color:#10182F;'>Targeting Cookies</h2>\n                                        </div>\n                                        <div class=\"form-check\">\n                                            <input class=\"form-check-input\" type=\"checkbox\" value=\"\" id=\"flexCheckChecked\" aria-label=\"Targeting Cookies\" style='margin-left:unset;'>\n                                        </div>\n                                        \n                                    </div>\n                                    <div>\n                                        <p class=\"text-wrap ff_made ls-4 me-0 ms-0 mb-0 mt-3\" style='font-size:14px;font-weight:400;color:#000000;'>These cookies create user profiles to deliver tailored promotional messages based on your browsing preferences. They do not collect personal information but identify your browser and device. Disabling them may result in less targeted advertising.</p>\n                                    </div>\n                                </div>\n                            </div>\n                        </div>\n                    </div>\n                    <div class='modal-footer pb-0 ps-0 pe-0 border-0 container' style='padding-top:14px;'>\n                        <div class='d-flex flex-row gap-1 align-items-center w-100 mb-3'>\n                            <div class=\"form-check\">\n                                <input class=\"form-check-input\" type=\"checkbox\" value=\"\" id=\"flexCheckChecked\" aria-label=\"California region data sharing preference\" checked>\n                            </div>\n                            <p class='ff_made_medium m-0' style='font-size:12px;font-weight:500;'>I confirm that I am from California region, do not sell/share my data</p>\n                        </div>\n                        <div class='d-flex flex-column flex-lg-row gap-4 align-items-center justify-content-center w-100'>\n                            <button type=\"button\" aria-label=\"Save Preferences\" id='cancel-btn-alert' class='btn w-100 btn-outline-primary modal_cst_btn bundle_alert_cst_btn'>SAVE PREFERENCES</button>\n                            <button type=\"button\" aria-label=\"Accept All Cookies\" id='con-btn-alert' class='btn btn-primary modal_cst_btn w-100'>ACCEPT ALL</button>\n                        </div>\n                    </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n</div>"):"<div class='loader-overlay '>\n            <div class='h-100'>\n            <div class='modal-dialog translate modal-dialog-centered modal-dialog-scrollable modal-dailog-right-bottom' style='max-width:494px'>\n                <div class='modal-content rounded-3 ".concat((null===(g=null==n?void 0:n.cssClasses)||void 0===g?void 0:g.popupParent)||"","' style='padding:30px;'>\n                    <div class=\"mod